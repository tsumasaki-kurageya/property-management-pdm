---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import ExplorerApp from '../components/explorer/ExplorerApp';
---

<StarlightPage
  frontmatter={{
    title: '業務エクスプローラー',
    description: 'ビルメンテナンス業務の前後・階層・関連を対話的に確認します。',
    template: 'splash',
    tableOfContents: false,
    pagefind: false,
  }}
>
  <div class="explorer-page">
    <ExplorerApp client:load />
    <noscript>
      <p class="explorer-noscript">
        業務エクスプローラーの操作にはJavaScriptが必要です。業務の詳細は
        <a href={`${import.meta.env.BASE_URL}reference/business-catalog/`}>業務カタログ</a>
        から確認できます。
      </p>
    </noscript>
  </div>
</StarlightPage>

<style>
  .explorer-page {
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .explorer-noscript {
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.75rem;
    padding: 1rem;
    background: var(--sl-color-orange-low);
  }

  :global(.explorer-page + .pagination-links) {
    display: none;
  }

  :global(body:has(.explorer-page) .main-pane) {
    width: 100%;
    max-width: none;
  }

  :global(body:has(.explorer-page) .main-pane > main),
  :global(body:has(.explorer-page) .main-pane .content-panel),
  :global(body:has(.explorer-page) .main-pane .sl-container) {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
  }

  :global(body:has(.explorer-page) .main-pane h1#_top),
  :global(body:has(.explorer-page) .main-pane .pagination-links),
  :global(body:has(.explorer-page) starlight-menu-button),
  :global(body:has(.explorer-page) #starlight__sidebar) {
    display: none;
  }

  @media (min-width: 50rem) {
    :global(body:has(.explorer-page) .main-frame) {
      padding-inline-start: 0;
    }
  }
</style>
