{
  "name": "property-management-pdm-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "generate:reference": "node scripts/generate-reference.mjs",
    "generate:explorer": "node scripts/generate-explorer-data.mjs",
    "check:reference": "node scripts/generate-reference.mjs --check && node scripts/check-reference-links.mjs",
    "check:explorer": "node scripts/generate-explorer-data.mjs --check",
    "check:release": "node scripts/check-release.mjs",
    "verify": "npm run check:explorer && npm run check && npm run build",
    "prebuild": "npm run check:reference && npm run check:explorer",
    "build": "astro build",
    "postbuild": "npm run check:release",
    "preview": "astro preview",
    "check": "astro check"
  },
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/starlight": "0.41.3",
    "@xyflow/react": "^12.11.2",
    "astro": "7.1.3",
    "astro-mermaid": "2.1.0",
    "elkjs": "^0.12.0",
    "mermaid": "11.16.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "5.9.3"
  }
}
